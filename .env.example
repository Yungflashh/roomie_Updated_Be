# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/roomie
MONGODB_URI_BACKUP=mongodb://localhost:27017/roomie_backup

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CLUSTER_MODE=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# OAuth - Apple
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./certs/apple-private-key.p8
APPLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/apple/callback

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=roomie-backups
AWS_S3_CDN_BUCKET=roomie-cdn

# Firebase Cloud Messaging
FCM_PROJECT_ID=your-firebase-project-id
FCM_PRIVATE_KEY=your-firebase-private-key
FCM_CLIENT_EMAIL=your-firebase-client-email
FCM_SERVICE_ACCOUNT_PATH=./certs/firebase-service-account.json

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret

# Mapbox
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# CDN
CDN_URL=https://cdn.yourdomain.com
CDN_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE_MB=50
MAX_PROFILE_PHOTOS=10
MAX_PROPERTY_PHOTOS=20

# Client URLs
CLIENT_URL=http://localhost:3000
CLIENT_URL_IOS=roomie://
CLIENT_URL_ANDROID=roomie://

# Email (Optional - for future notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password

# Backup Schedule (cron format)
BACKUP_CRON_SCHEDULE=0 2 * * *

# Video Call Settings
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-certificate

# AI/ML Services (Optional)
OPENAI_API_KEY=your-openai-key

# Monitoring
SENTRY_DSN=your-sentry-dsn

# Location Update Interval (in milliseconds)
LOCATION_CHECK_INTERVAL=3600000

# Gamification
DAILY_CHALLENGE_RESET_HOUR=0
WEEKLY_LEADERBOARD_RESET_DAY=0
